# WhyOps Production Environment Template
# Copy this to .env and fill in your values

# ===========================================
# DATABASE - Azure Database for PostgreSQL
# ===========================================
DATABASE_URL=postgresql://username:password@db-host:5432/whyops
DB_SSL=false
DB_SSL_REJECT_UNAUTHORIZED=false

# ===========================================
# APPLICATION
# ===========================================
NODE_ENV=production
LOG_LEVEL=info

# ===========================================
# SERVICE PORTS (internal)
# ===========================================
PROXY_PORT=8080
ANALYSE_PORT=8081
AUTH_PORT=8082

# ===========================================
# SERVICE URLs - Use HTTPS for production!
# ===========================================
# These are used by each service to communicate with each other
PROXY_URL=https://proxy.whyops.com
ANALYSE_URL=https://a.whyops.com
AUTH_URL=https://auth.whyops.com

# ===========================================
# SECURITY - REQUIRED - Generate secure secrets
# ===========================================
# Generate with: openssl rand -base64 32
JWT_SECRET=<generate-and-paste-jwt-secret>

# Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=<generate-and-paste-better-auth-secret>

API_KEY_PREFIX=whyops

# ===========================================
# RATE LIMITING
# ===========================================
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# ===========================================
# PROXY CONFIGURATION
# ===========================================
PROXY_TIMEOUT_MS=60000
PROXY_MAX_RETRIES=3

# ===========================================
# REDIS (Queue/Cache/Rate Limit)
# ===========================================
# Use TLS endpoint in production.
# Example: rediss://user:password@your-redis-host:6379
REDIS_URL=rediss://your-redis-host:6379
REDIS_KEY_PREFIX=whyops

# Event Queue
EVENTS_STREAM_NAME=whyops:events
EVENTS_DLQ_STREAM_NAME=whyops:events:dlq
EVENTS_STREAM_GROUP=whyops-analyse-workers
EVENTS_STREAM_MAX_LEN=200000
EVENTS_STREAM_BATCH_SIZE=100
EVENTS_STREAM_BLOCK_MS=2000
EVENTS_STREAM_RETRY_MAX=5
EVENTS_WORKER_ENABLED=true

# Cache
AUTH_APIKEY_CACHE_TTL_SEC=60
PROVIDER_CACHE_TTL_SEC=60
APIKEY_LAST_USED_WRITE_INTERVAL_SEC=300

# V1 Limits
MAX_AGENTS_PER_PROJECT=20
MAX_TRACES_PER_AGENT=10000
MAX_TRACES_PER_ENTITY=5000
DEFAULT_TRACE_SAMPLING_RATE=0.2

# ===========================================
# BETTER AUTH
# ===========================================
# Must match your deployed auth domain
BETTER_AUTH_URL=https://auth.whyops.com

# ===========================================
# TRUSTED ORIGINS
# ===========================================
# Comma-separated list of allowed origins for CORS and auth
TRUSTED_ORIGINS=https://app.whyops.com,https://whyops.com,https://*.whyops.com

# Optional Better Auth cookie domain.
# Leave unset to use a host-only cookie on auth.whyops.com, or set to
# .whyops.com if you intentionally want the cookie shared across subdomains.
# COOKIE_DOMAIN=.whyops.com

# ===========================================
# OAUTH - Optional (for social login)
# ===========================================
# GitHub: https://github.com/settings/developers
AUTHGH_CLIENT_ID=
AUTHGH_CLIENT_SECRET=

# Google: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ===========================================
# EMAIL - Required for magic links
# ===========================================
# Maileroo: https://maileroo.com
MAILEROO_API_KEY=
MAILEROO_FROM_EMAIL=noreply@yourdomain.com
MAILEROO_FROM_NAME=WhyOps
