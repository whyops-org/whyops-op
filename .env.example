# Database Configuration
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/whyops
# OR use individual settings:
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=whyops
# DB_USER=postgres
# DB_PASSWORD=postgres
# DB_POOL_MAX=20
# DB_POOL_MIN=5

# Application Environment
NODE_ENV=development
LOG_LEVEL=info

# Service Ports
PROXY_PORT=8080
ANALYSE_PORT=8081
AUTH_PORT=8082

# Service URLs (for internal communication)
PROXY_URL=http://localhost:8080
ANALYSE_URL=http://localhost:8081
AUTH_URL=http://localhost:8082

# Security
JWT_SECRET=your-super-secret-jwt-key-change-in-production-use-openssl-rand-base64-32
API_KEY_PREFIX=whyops

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# Proxy Configuration
PROXY_TIMEOUT_MS=60000
PROXY_MAX_RETRIES=3

# Better Auth Configuration
BETTER_AUTH_URL=http://localhost:8082
BETTER_AUTH_SECRET=your-better-auth-secret-change-in-production-min-32-chars

# OAuth - GitHub
# Get credentials from: https://github.com/settings/developers
# Callback URL: http://localhost:8082/api/auth/callback/github
AUTHGH_CLIENT_ID=
AUTHGH_CLIENT_SECRET=

# OAuth - Google
# Get credentials from: https://console.cloud.google.com/apis/credentials
# Callback URL: http://localhost:8082/api/auth/callback/google
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# Email - Maileroo
# Get API key from: https://maileroo.com
# Required for magic link authentication
MAILEROO_API_KEY=your_maileroo_api_key
MAILEROO_FROM_EMAIL=noreply@whyops.com
MAILEROO_FROM_NAME=WhyOps
