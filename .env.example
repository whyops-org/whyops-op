# Database Configuration
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/whyops
# OR use individual settings:
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=whyops
# DB_USER=postgres
# DB_PASSWORD=postgres
# DB_POOL_MAX=20
# DB_POOL_MIN=5

# Application Environment
NODE_ENV=development
LOG_LEVEL=info

# Service Ports
PROXY_PORT=8080
ANALYSE_PORT=8081
AUTH_PORT=8082

# Service URLs (for internal communication)
PROXY_URL=http://localhost:8080
ANALYSE_URL=http://localhost:8081
AUTH_URL=http://localhost:8082

# Security
JWT_SECRET=your-super-secret-jwt-key-change-in-production-use-openssl-rand-base64-32
API_KEY_PREFIX=whyops

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# Proxy Configuration
PROXY_TIMEOUT_MS=60000
PROXY_MAX_RETRIES=3

# Redis (TLS URL)
# Example: rediss://<host>:6379
REDIS_URL=rediss://your-redis-host:6379
REDIS_KEY_PREFIX=whyops

# Event Queue
EVENTS_STREAM_NAME=whyops:events
EVENTS_DLQ_STREAM_NAME=whyops:events:dlq
EVENTS_STREAM_GROUP=whyops-analyse-workers
EVENTS_STREAM_MAX_LEN=200000
EVENTS_STREAM_BATCH_SIZE=100
EVENTS_STREAM_BLOCK_MS=2000
EVENTS_STREAM_RETRY_MAX=5
EVENTS_WORKER_ENABLED=true

# Cache
AUTH_APIKEY_CACHE_TTL_SEC=60
PROVIDER_CACHE_TTL_SEC=60
APIKEY_LAST_USED_WRITE_INTERVAL_SEC=300

# V1 Limits
MAX_AGENTS_PER_PROJECT=20
MAX_TRACES_PER_AGENT=10000
MAX_TRACES_PER_ENTITY=5000
DEFAULT_TRACE_SAMPLING_RATE=0.2

# Better Auth Configuration
BETTER_AUTH_URL=http://localhost:8082
BETTER_AUTH_SECRET=your-better-auth-secret-change-in-production-min-32-chars

# Trusted Origins (comma-separated, for CORS and auth)
TRUSTED_ORIGINS=http://localhost:3000,http://localhost:5173

# Optional cookie domain for Better Auth.
# Leave unset for localhost development. Set this in production only if you
# need a shared parent-domain cookie, for example: .whyops.com
# COOKIE_DOMAIN=

# OAuth - GitHub
# Get credentials from: https://github.com/settings/developers
# Callback URL: http://localhost:8082/api/auth/callback/github
AUTHGH_CLIENT_ID=
AUTHGH_CLIENT_SECRET=

# OAuth - Google
# Get credentials from: https://console.cloud.google.com/apis/credentials
# Callback URL: http://localhost:8082/api/auth/callback/google
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# Email - Maileroo
# Get API key from: https://maileroo.com
# Required for magic link authentication
MAILEROO_API_KEY=your_maileroo_api_key
MAILEROO_FROM_EMAIL=noreply@whyops.com
MAILEROO_FROM_NAME=WhyOps

# LLM Judge Configuration (via LiteLLM proxy)
# LiteLLM proxy base URL — routes to Azure/OpenAI/Anthropic behind the scenes
JUDGE_LLM_BASE_URL=https://litellm.whiteocean-2fb73b80.centralindia.azurecontainerapps.io/v1
JUDGE_LLM_API_KEY=sk-your-litellm-key-here
JUDGE_LLM_MODEL=azure/gpt-4.1
JUDGE_LLM_TEMPERATURE=0
JUDGE_MAX_RETRIES=2
