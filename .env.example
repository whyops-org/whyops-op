# Database Configuration
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/whyops
# OR use individual settings:
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=whyops
# DB_USER=postgres
# DB_PASSWORD=postgres
# DB_POOL_MAX=20
# DB_POOL_MIN=5

# Application Environment
NODE_ENV=development
LOG_LEVEL=info

# Service Ports
PROXY_PORT=8080
ANALYSE_PORT=8081
AUTH_PORT=8082

# Service URLs (for internal communication)
PROXY_URL=http://localhost:8080
ANALYSE_URL=http://localhost:8081
AUTH_URL=http://localhost:8082

# Security
JWT_SECRET=your-super-secret-jwt-key-change-in-production-use-openssl-rand-base64-32
API_KEY_PREFIX=whyops

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# Proxy Configuration
PROXY_TIMEOUT_MS=60000
PROXY_MAX_RETRIES=3
