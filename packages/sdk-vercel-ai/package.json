{
  "name": "@whyops/vercel-ai-sdk",
  "version": "0.1.1",
  "description": "WhyOps observability integration for the Vercel AI SDK",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/whyops-org/whyops-op.git",
    "directory": "packages/sdk-vercel-ai"
  },
  "homepage": "https://whyops.com",
  "bugs": {
    "url": "https://github.com/whyops-org/whyops-op/issues"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "rm -rf dist && node ../../node_modules/typescript/bin/tsc -p tsconfig.json",
    "typecheck": "node ../../node_modules/typescript/bin/tsc --noEmit",
    "prepack": "npm run build",
    "test:context": "node --import tsx context.test.ts",
    "test": "node --import tsx test.ts"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "keywords": [
    "whyops",
    "observability",
    "ai",
    "agents",
    "llm",
    "vercel",
    "ai-sdk",
    "tracing"
  ],
  "peerDependencies": {
    "@whyops/sdk": ">=0.1.1",
    "ai": ">=5.0.0"
  },
  "devDependencies": {
    "@ai-sdk/openai": "^3.0.49",
    "@whyops/sdk": "*",
    "ai": "^6.0.0",
    "typescript": "^5.4.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
